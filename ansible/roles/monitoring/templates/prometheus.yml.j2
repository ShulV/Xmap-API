global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  - job_name: 'spotic'
    scheme: https
    metrics_path: /actuator/prometheus
    static_configs:
      - targets:
          - test.spotic.ru
        labels:
          application: spotic

  - job_name: 'prometheus'
    static_configs:
      - targets:
          - localhost:9090
        labels:
          application: prometheus